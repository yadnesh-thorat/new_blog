# ── Dependencies ─────────────────────────────────────────────────────────────
/node_modules

# ── Vite build output ────────────────────────────────────────────────────────
/dist

# ── Temporary / scratch directories ─────────────────────────────────────────
/.tmp_scratch
*.tmp

# ── Environment / secrets (never commit) ────────────────────────────────────
.env
.env.*
!.env.example

# ── Local seeder scripts (contain Firestore credentials) ────────────────────
seed_*.mjs

# ── Editor / OS artifacts ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem

# ── Debug logs ───────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Vercel ───────────────────────────────────────────────────────────────────
.vercel

# ── Test coverage ────────────────────────────────────────────────────────────
/coverage

# ── AI agent config files (not needed in production repo) ────────────────────
CLAUDE.md
AGENTS.md
